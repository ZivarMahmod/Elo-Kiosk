{
  "expo": {
    "name": "Corevo Kiosk",
    "slug": "corevo-kiosk",
    "version": "1.0.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "corevo-kiosk",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2c3e35"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2c3e35"
      },
      "package": "com.corevo.kiosk",
      "versionCode": 2,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ],
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "bundleIdentifier": "com.corevo.kiosk",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "87423bbd-a8ec-4961-a1f1-4123d3417408"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "zivar"
  }
}
